# Copia este archivo a .env y ajusta los valores

PORT=4000

# DATA_SOURCE: origen de los datos del mapa (SOLO LECTURA)
#   mock  -> datos de prueba en memoria (para ver la UI sin BD)
#   mssql -> lee de SQL Server (ZALM_UBICACIONES / ZALM_ALMACEN_OCUPADO)
DATA_SOURCE=mock

# Entidad y almacen que se consultan en SQL Server
ENTIDAD=01
ALMACEN=01

# DB_DIALECT: "sqlite" para el prototipo local, "mssql" para la BD real del almacen
DB_DIALECT=sqlite

# --- Solo se usa si DB_DIALECT=sqlite ---
SQLITE_STORAGE=./data/almacen3d.sqlite

# --- Solo se usa si DB_DIALECT=mssql (BD real del almacen) ---
MSSQL_HOST=localhost
MSSQL_PORT=1433
MSSQL_DATABASE=Almacen
MSSQL_USER=usuario
MSSQL_PASSWORD=contrasena
MSSQL_ENCRYPT=true
MSSQL_TRUST_SERVER_CERTIFICATE=true
