# Copia este archivo a .env y ajusta los valores

PORT=4000

# DATA_SOURCE: origen de los datos del mapa (SOLO LECTURA)
#   mock  -> datos de prueba en memoria (para ver la UI sin BD)
#   mssql -> lee de SQL Server (ZALM_UBICACIONES / ZALM_ALMACEN_OCUPADO)
DATA_SOURCE=mock

# Entidad y almacen que se consultan en SQL Server
ENTIDAD=01
ALMACEN=01

# DB_DIALECT: "sqlite" para el prototipo local, "mssql" para la BD real del almacen
DB_DIALECT=sqlite

# --- Solo se usa si DB_DIALECT=sqlite ---
SQLITE_STORAGE=./data/almacen3d.sqlite

# --- Solo se usa si DB_DIALECT=mssql (BD real del almacen) ---
# HOST: solo la IP/nombre, SIN la instancia. Ej: 192.168.66.37
# (si pones 192.168.66.37\SQLSERVER22 se separa la instancia automaticamente)
MSSQL_HOST=192.168.66.37
MSSQL_PORT=1433

# Instancia con nombre (ej: SQLSERVER22). Dejar vacio si es la instancia por defecto.
MSSQL_INSTANCE=SQLSERVER22

# Como conectar a la instancia con nombre:
#   false -> por puerto TCP fijo (MSSQL_PORT). La instancia debe escuchar en ese puerto.
#   true  -> resuelve el puerto via SQL Server Browser (UDP 1434 abierto + servicio activo).
MSSQL_USE_INSTANCE=false

MSSQL_DATABASE=Almacen
MSSQL_USER=usuario
MSSQL_PASSWORD=contrasena
MSSQL_ENCRYPT=true
MSSQL_TRUST_SERVER_CERTIFICATE=true

# Timeouts (ms), opcionales
MSSQL_CONNECT_TIMEOUT=15000
MSSQL_REQUEST_TIMEOUT=30000
