# Copia este archivo a .env y ajusta los valores

PORT=4000

# DATA_SOURCE: origen de los datos del mapa (SOLO LECTURA)
#   mock  -> datos de prueba en memoria (para ver la UI sin BD)
#   mssql -> lee de SQL Server (ZALM_UBICACIONES / ZALM_ALMACEN_OCUPADO)
DATA_SOURCE=mock

# Entidad y almacen que se consultan en SQL Server
ENTIDAD=01
ALMACEN=01

# DB_DIALECT: "sqlite" para el prototipo local, "mssql" para la BD real del almacen
DB_DIALECT=sqlite

# --- Solo se usa si DB_DIALECT=sqlite ---
SQLITE_STORAGE=./data/almacen3d.sqlite

# --- Solo se usa si DB_DIALECT=mssql (BD real del almacen) ---
# HOST: solo la IP/nombre, SIN la instancia. Ej: 10.0.0.10
# (si pones HOST\INSTANCIA se separa la instancia automaticamente)
MSSQL_HOST=servidor-sql
MSSQL_PORT=1433

# Instancia con nombre. Dejar vacio si es la instancia por defecto.
# Si se indica, se conecta por instancia via SQL Server Browser (como el DSN de PHP),
# sin usar MSSQL_PORT. Para forzar puerto TCP fijo en su lugar: MSSQL_USE_INSTANCE=false
MSSQL_INSTANCE=NOMBRE_INSTANCIA
MSSQL_USE_INSTANCE=true

MSSQL_DATABASE=NombreBaseDatos
MSSQL_USER=usuario
MSSQL_PASSWORD=contrasena
# Si el DSN usa Encrypt=no, pon MSSQL_ENCRYPT=false
MSSQL_ENCRYPT=false
MSSQL_TRUST_SERVER_CERTIFICATE=true

# Timeouts (ms), opcionales
MSSQL_CONNECT_TIMEOUT=15000
MSSQL_REQUEST_TIMEOUT=30000
